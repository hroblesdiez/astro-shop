---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Bestsellers from '../components/Bestsellers.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import { getBestsellers, getTestimonials } from '../lib/products';

export const prerender = true;

let products: any[] = [];
let testimonials: any[] = [];
try {
  const results = await Promise.all([getBestsellers(4), getTestimonials()]);
  products = results[0];
  testimonials = results[1];
} catch (err) {
  console.error("[index.astro] Error fetching homepage data:", err);
}
---

<Layout title="Home">
  <Hero />
  <Bestsellers products={products} />
  <CategoryGrid />
  <Testimonials testimonials={testimonials} />
</Layout>
