---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Bestsellers from '../components/Bestsellers.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import { getBestsellers, getTestimonials } from '../lib/products';

const [products, testimonials] = await Promise.all([
  getBestsellers(4),
  getTestimonials(),
]);

console.log('bestsellers:', JSON.stringify(products, null, 2));
---

<Layout title="Home">
  <Hero />
  <Bestsellers products={products} />
  <CategoryGrid />
  <Testimonials testimonials={testimonials} />
</Layout>
