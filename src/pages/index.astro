---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Bestsellers from '../components/Bestsellers.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import Testimonials from '../components/Testimonials.astro';
import { getBestsellers, getTestimonials } from '../lib/products';

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=300, stale-while-revalidate=60, stale-if-error=86400',
);

const [products, testimonials] = await Promise.all([
  getBestsellers(4),
  getTestimonials(),
]);
---

<Layout title="Home">
  <Hero />
  <Bestsellers products={products} />
  <CategoryGrid />
  <Testimonials testimonials={testimonials} />
</Layout>
