---
import BillingForm from './BillingForm.astro';
import ShippingForm from './ShippingForm.astro';
import OrderReview from './OrderReview.astro';
import type { StoreCart } from '../../lib/store-api';

export interface Props {
  cart: StoreCart;
}

const { cart } = Astro.props;
---

<div class="checkout-form-wrapper" data-checkout-form>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-[var(--color-text-base)] mb-12">Checkout</h1>

    <form id="checkout-form" class="grid gap-8 lg:grid-cols-3 lg:gap-12">
      <div class="lg:col-span-2 space-y-6">
        <div id="errors-container" role="alert" aria-live="polite"></div>

        <ShippingForm />
        <BillingForm />

        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-lg)] p-6 sm:p-8">
          <fieldset>
            <legend class="font-heading text-xl text-[var(--color-text-base)] mb-6 pb-4 border-b border-[var(--color-border)] w-full">
              Additional Information
            </legend>

            <div>
              <label for="order-notes" class="block text-sm font-medium text-[var(--color-text-base)] mb-1.5">
                Order Notes (Optional)
              </label>
              <textarea
                id="order-notes"
                name="orderNotes"
                rows="4"
                placeholder="Special instructions or delivery notes..."
                class="w-full px-3 py-2.5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[var(--radius-sm)] text-sm text-[var(--color-text-base)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-btn-cta)] focus:border-[var(--color-btn-cta)] transition-colors"
              ></textarea>
            </div>
          </fieldset>
        </div>

        <div class="flex sm:justify-end">
          <button
            type="submit"
            id="checkout-submit"
            class="w-full sm:w-auto sm:min-w-[260px] px-8 py-3.5 bg-[var(--color-btn-cart)] text-white font-medium text-base rounded-[var(--radius-md)] shadow-sm hover:brightness-95 active:brightness-90 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Place Order
          </button>
        </div>
      </div>

      <div class="lg:col-span-1">
        <div class="sticky top-4">
          <OrderReview cart={cart} />
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  import { getCachedCheckoutState, saveCheckoutState, saveOrderConfirmation } from '../../lib/checkout-state';
  import { submitCheckout } from '../../lib/checkout-service';
  import { clearCartCache } from '../../lib/cart';

  // Billing fields that mirror shipping when "same as shipping" is checked.
  // Email and phone are billing-only and are never synced.
  const SYNCED_FIELDS = ['firstName', 'lastName', 'country', 'state', 'address1', 'address2', 'city', 'postcode'] as const;

  function initCheckoutForm() {
    console.log('[CheckoutForm] Initializing...');

    const form = document.getElementById('checkout-form') as HTMLFormElement;
    const submitBtn = document.getElementById('checkout-submit') as HTMLButtonElement;
    const errorsContainer = document.getElementById('errors-container') as HTMLDivElement;
    const sameAsShippingCheckbox = document.getElementById('billing-same-as-shipping') as HTMLInputElement | null;
    const billingWrapper = document.querySelector('[data-form="billing"]') as HTMLElement | null;

    if (!form || !submitBtn) {
      console.warn('[CheckoutForm] Required elements not found');
      return;
    }

    const cachedState = getCachedCheckoutState();

    const populateForm = (state: any) => {
      Object.entries(state).forEach(([key, value]: [string, any]) => {
        if (typeof value === 'object') {
          Object.entries(value).forEach(([subKey, subValue]: [string, any]) => {
            const input = form.querySelector(`[name="${key}.${subKey}"]`) as HTMLInputElement | HTMLTextAreaElement;
            if (input && subValue) input.value = subValue;
          });
        } else if (key === 'orderNotes' && value) {
          const textarea = form.querySelector(`[name="${key}"]`) as HTMLTextAreaElement;
          if (textarea) textarea.value = value;
        }
      });
    };

    populateForm(cachedState);

    const setBillingFieldsDisabled = (disabled: boolean) => {
      SYNCED_FIELDS.forEach(field => {
        const el = form.querySelector(`[name="billing.${field}"]`) as HTMLInputElement | HTMLSelectElement | null;
        if (el) el.disabled = disabled;
      });
    };

    const syncBillingFromShipping = () => {
      SYNCED_FIELDS.forEach(field => {
        const shippingEl = form.querySelector(`[name="shipping.${field}"]`) as HTMLInputElement | HTMLSelectElement | null;
        const billingEl = form.querySelector(`[name="billing.${field}"]`) as HTMLInputElement | HTMLSelectElement | null;
        if (!shippingEl || !billingEl) return;

        if (field === 'country') {
          billingEl.value = shippingEl.value;
          // Repopulate billing's state dropdown for the new country before
          // copying the state value below.
          const updateFn = (billingWrapper as any)?.__updateBillingStateField;
          if (typeof updateFn === 'function') {
            updateFn(shippingEl.value);
          }
          return;
        }

        billingEl.value = shippingEl.value;
      });

      // State must run after country so the dropdown options exist.
      const shippingState = form.querySelector('[name="shipping.state"]') as HTMLSelectElement | null;
      const billingState = form.querySelector('[name="billing.state"]') as HTMLSelectElement | null;
      if (shippingState && billingState) {
        billingState.value = shippingState.value;
      }

      const stateCopy = structuredClone(getCachedCheckoutState());
      SYNCED_FIELDS.forEach(field => {
        (stateCopy.billing as any)[field] = (stateCopy.shipping as any)[field];
      });
      saveCheckoutState(stateCopy);
    };

    if (sameAsShippingCheckbox) {
      sameAsShippingCheckbox.addEventListener('change', () => {
        if (sameAsShippingCheckbox.checked) {
          syncBillingFromShipping();
          setBillingFieldsDisabled(true);
        } else {
          setBillingFieldsDisabled(false);
        }
      });
    }

    form.addEventListener('change', (e: Event) => {
      const target = e.target as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
      const name = target.name;
      if (!name) return;

      const stateCopy = structuredClone(getCachedCheckoutState());
      const [section, field] = name.split('.');

      if (section && field) {
        (stateCopy[section as keyof typeof stateCopy] as any)[field] = target.value;
      } else if (section === 'orderNotes') {
        stateCopy.orderNotes = target.value;
      }

      saveCheckoutState(stateCopy);

      // Keep billing mirrored to shipping while sync mode is active.
      if (
        sameAsShippingCheckbox?.checked &&
        section === 'shipping' &&
        SYNCED_FIELDS.includes(field as (typeof SYNCED_FIELDS)[number])
      ) {
        syncBillingFromShipping();
      }
    });

    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Processing...';
      errorsContainer.innerHTML = '';

      try {
        const state = getCachedCheckoutState();
        const response = await submitCheckout(state);

        if (!response.success) {
          errorsContainer.innerHTML = `
            <div class="p-4 bg-red-50 border border-red-200 rounded-md">
              <p class="text-red-800 font-medium mb-2">There were errors with your order:</p>
              <ul class="text-red-700 space-y-1 text-sm">
                ${response.errors?.map(err => `<li>• ${err.message}</li>`).join('') || '<li>Unknown error</li>'}
              </ul>
            </div>
          `;
          window.scrollTo({ top: 0, behavior: 'smooth' });
          return;
        }

        saveOrderConfirmation(response.orderId!, response.orderKey!, state.billing.email!);
        clearCartCache();
        window.location.href = `/checkout/confirmation/${response.orderId}`;
      } catch (error) {
        console.error('[CheckoutForm] Unexpected error:', error);
        errorsContainer.innerHTML = `
          <div class="p-4 bg-red-50 border border-red-200 rounded-md">
            <p class="text-red-800 font-medium">An unexpected error occurred. Please try again.</p>
          </div>
        `;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCheckoutForm);
  } else {
    initCheckoutForm();
  }
</script>
