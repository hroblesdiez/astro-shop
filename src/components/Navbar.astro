---
import MiniCart from './MiniCart.astro';
import { getCategories } from '../lib/products';

const categories = await getCategories();
---

<header class="border-b border-neutral-200 sticky top-0 bg-white z-50">
  <nav class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tight">ASTRO SHOP</a>

    <ul class="hidden md:flex items-center gap-8">
      <li>
        <a href="/" class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors">
          Home
        </a>
      </li>
      <li>
        <a href="/products" class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors">
          Shop
        </a>
      </li>
      <li
        id="categories-dropdown"
        class="relative group"
        data-open="false"
      >
        <button
          id="categories-toggle"
          class="flex items-center gap-1 text-sm text-neutral-600 hover:text-neutral-900 transition-colors cursor-pointer"
          aria-label="Categories"
        >
          Categories
          <svg class="w-3 h-3 mt-0.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <ul
          class="absolute top-full left-0 min-w-[220px] bg-(--color-surface) border border-(--color-border) rounded-[var(--radius-md)] shadow-lg py-2 z-50
            invisible opacity-0 translate-y-1 transition-all duration-200
            group-hover:visible group-hover:opacity-100 group-hover:translate-y-0
            data-[open=true]:visible data-[open=true]:opacity-100 data-[open=true]:translate-y-0"
        >
          {categories.map((cat: any) => (
            <li>
              <a
                href={`/categories/${cat.slug}`}
                class="block px-4 py-2.5 text-sm text-neutral-700 hover:bg-(--color-primary) hover:text-(--color-text-base) transition-colors"
              >
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </li>
    </ul>

    <div class="flex items-center gap-4">
      <button
        id="mobile-menu-toggle"
        class="md:hidden text-neutral-600 hover:text-neutral-900 transition-colors cursor-pointer p-1"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      <button
        id="cart-button"
        class="relative pr-4 text-sm font-medium hover:text-neutral-600 transition-colors cursor-pointer"
        aria-label="Open cart"
      >
        Cart
        <span
          id="cart-count"
          class="absolute -top-2 right-0 bg-neutral-900 text-white text-xs w-4 h-4 rounded-full flex items-center justify-center font-bold"
        >
          0
        </span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 md:hidden invisible opacity-0 transition-all duration-300"
    data-open="false"
  >
    <div id="mobile-backdrop" class="absolute inset-0 bg-black/30"></div>
    <div class="relative ml-auto w-72 h-full bg-(--color-surface) shadow-xl translate-x-full transition-transform duration-300">
      <div class="flex justify-end p-4">
        <button
          id="mobile-close"
          class="text-neutral-600 hover:text-neutral-900 transition-colors cursor-pointer p-1"
          aria-label="Close menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <ul class="px-6 space-y-1">
        <li>
          <a href="/" class="block py-3 text-sm text-neutral-700 hover:text-(--color-text-base) font-medium border-b border-(--color-border)">
            Home
          </a>
        </li>
        <li>
          <a href="/products" class="block py-3 text-sm text-neutral-700 hover:text-(--color-text-base) font-medium border-b border-(--color-border)">
            Shop
          </a>
        </li>
        <li>
          <button
            id="mobile-categories-toggle"
            class="w-full flex items-center justify-between py-3 text-sm text-neutral-700 hover:text-(--color-text-base) font-medium border-b border-(--color-border) cursor-pointer"
          >
            Categories
            <svg id="mobile-categories-arrow" class="w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul id="mobile-categories-list" class="hidden pl-4 pb-2 space-y-1">
            {categories.map((cat: any) => (
              <li>
                <a
                  href={`/categories/${cat.slug}`}
                  class="block py-2 text-sm text-neutral-600 hover:text-(--color-text-base) transition-colors"
                >
                  {cat.name}
                </a>
              </li>
            ))}
          </ul>
        </li>
      </ul>
    </div>
  </div>
</header>

<!-- Global Shell Inclusion of the Slide-over Panel -->
<MiniCart />

<script>
  import { getCachedCart } from '../lib/cart';
  import type { StoreCart } from '../lib/store-api';

  function initNavbarCart() {
    const cartBtn = document.getElementById('cart-button');
    const cartCount = document.getElementById('cart-count');

    if (!cartBtn || !cartCount) return;

    function updateBadgeCount(cart: StoreCart | null) {
      if (!cartCount) return;
      if (!cart || !cart.items) {
        cartCount.textContent = '0';
        return;
      }

      const totalQty = cart.items.reduce((sum, item) => sum + item.quantity, 0);
      cartCount.textContent = totalQty.toString();
    }

    updateBadgeCount(getCachedCart());

    window.addEventListener('cart-updated', ((e: CustomEvent<StoreCart>) => {
      updateBadgeCount(e.detail);
    }) as EventListener);

    cartBtn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('toggle-mini-cart'));
    });
  }

  function initCategoriesDropdown() {
    const dropdown = document.getElementById('categories-dropdown');
    const toggle = document.getElementById('categories-toggle');
    if (!dropdown || !toggle) return;

    function close() {
      dropdown.dataset.open = 'false';
    }

    function isOpen() {
      return dropdown.dataset.open === 'true';
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.dataset.open = isOpen() ? 'false' : 'true';
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) {
        close();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }

  function initMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-backdrop');
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-close');
    const catToggle = document.getElementById('mobile-categories-toggle');
    const catList = document.getElementById('mobile-categories-list');
    const catArrow = document.getElementById('mobile-categories-arrow');
    const panel = menu?.querySelector('.ml-auto');

    if (!menu || !toggleBtn || !closeBtn || !panel) return;

    const m = menu;
    const p = panel;

    function open() {
      m.dataset.open = 'true';
      m.classList.remove('invisible', 'opacity-0');
      m.classList.add('visible', 'opacity-100');
      p.classList.remove('translate-x-full');
      p.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      m.dataset.open = 'false';
      p.classList.remove('translate-x-0');
      p.classList.add('translate-x-full');
      m.classList.remove('visible', 'opacity-100');
      m.classList.add('invisible', 'opacity-0');
      document.body.style.overflow = '';
    }

    toggleBtn.addEventListener('click', () => {
      if (m.dataset.open === 'true') {
        close();
      } else {
        open();
      }
    });

    closeBtn.addEventListener('click', close);
    if (backdrop) backdrop.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && m.dataset.open === 'true') close();
    });

    // Close when a nav link is clicked
    m.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', close);
    });

    // Mobile categories toggle
    if (catToggle && catList && catArrow) {
      catToggle.addEventListener('click', () => {
        const expanded = catToggle.dataset.expanded === 'true';
        catToggle.dataset.expanded = expanded ? 'false' : 'true';
        catList.classList.toggle('hidden');
        catArrow.classList.toggle('rotate-180');
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initNavbarCart();
      initCategoriesDropdown();
      initMobileMenu();
    });
  } else {
    initNavbarCart();
    initCategoriesDropdown();
    initMobileMenu();
  }
</script>
