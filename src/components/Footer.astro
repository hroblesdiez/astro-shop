---
const shopLinks = [
  { href: '/products', label: 'All Products' },
  { href: '/#bestsellers', label: 'Bestsellers' },
];

const companyLinks = [
  { href: '/shipping', label: 'Shipping' },
  { href: '/returns', label: 'Returns' },
];
---

<footer class="bg-(--color-primary) border-t border-(--color-border)">

  <div class="border-b border-(--color-border)">
    <div class="max-w-7xl mx-auto px-4 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="font-(--font-heading) text-2xl text-(--color-text-base) mb-1">Stay Connected</h3>
        <p class="text-(--color-text-muted) text-sm">Subscribe for exclusive offers and new arrivals.</p>
      </div>
      <form class="flex w-full md:w-auto gap-0" onsubmit="return false;">
        <input
          type="email"
          placeholder="Your email address"
          class="flex-1 md:w-72 px-4 py-3 text-sm border border-(--color-border) bg-(--color-surface) outline-none focus:border-(--color-btn-cta) transition-colors"
        />
        <button
          type="submit"
          class="bg-(--color-btn-cta) text-white px-6 py-3 text-sm font-medium hover:bg-(--color-btn-cta-hover) transition-colors whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12 grid grid-cols-2 md:grid-cols-3 gap-8">
    <div class="col-span-2 md:col-span-1">
      <a href="/" class="font-(--font-heading) text-2xl text-(--color-text-base)">Astro Shop</a>
      <p class="text-(--color-text-muted) text-sm mt-3 leading-relaxed max-w-xs">
        A headless WooCommerce store built with Astro, GraphQL and Stripe. Portfolio project.
      </p>
    </div>

    <div>
      <h4 class="text-xs font-semibold tracking-widest uppercase text-(--color-text-base) mb-4">Shop</h4>
      <ul class="flex flex-col gap-2">
        {shopLinks.map(({ href, label }) => (
          <li>
            <a href={href} class="text-sm text-(--color-text-muted) hover:text-(--color-text-base) transition-colors">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-xs font-semibold tracking-widest uppercase text-(--color-text-base) mb-4">Company</h4>
      <ul class="flex flex-col gap-2">
        {companyLinks.map(({ href, label }) => (
          <li>
            <a href={href} class="text-sm text-(--color-text-muted) hover:text-(--color-text-base) transition-colors">
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <div class="border-t border-(--color-border)">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col md:flex-row items-center justify-between gap-2">
      <p class="text-xs text-(--color-text-muted)">© 2025 Astro Shop. Portfolio project — not a real store.</p>
      <p class="text-xs text-(--color-text-muted)">Built with Astro · WooCommerce · Stripe</p>
    </div>
  </div>

</footer>
