---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'product';
}

const {
  title,
  description = 'A headless WooCommerce store built with Astro, GraphQL and Stripe.',
  image = '/og-default.png',
  type = 'website',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : new URL(Astro.url.href);

const fullTitle = `${title} | Astro Shop`;

const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;

const ogImage = Astro.site
  ? new URL(image, Astro.site)
  : new URL(image, Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="http://138.2.172.187" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="preload"
      as="image"
      href="/images/categories/hero-800w.webp"
      imagesrcset="/images/categories/hero-400w.webp 400w, /images/categories/hero-800w.webp 800w, /images/categories/hero-1200w.webp 1200w"
      imagesizes="(max-width: 768px) 100vw, 50vw"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Humberto Aranceta" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Astro Shop" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
    <script>
      import '../lib/vitals';
    </script>

    {umamiWebsiteId && (
      <script
        defer
        src="/umami/script.js"
        data-website-id={umamiWebsiteId}
      ></script>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-white text-neutral-900 antialiased">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import { initializeCountryFromGeolocation } from '../lib/country-sync';
  initializeCountryFromGeolocation().catch(console.warn);
</script>